{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "lefthook install",
    "knip": "knip",
    "spellcheck": "cspell lint --cache .",
    "cspell": "cspell lint --cache .",
    "typecheck": "bun nx run @org/frontend:typecheck",
    "verify": "bun nx sync:check && bun nx run-many -t typecheck -p @org/frontend --parallel=2",
    "verify:push": "bun nx run-many -t build -p @org/frontend",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "private": true,
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@nx/devkit": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/react": "23.0.1",
    "@nx/rsbuild": "23.0.1",
    "@playwright/test": "^1.37.0",
    "@rsbuild/core": "1.1.10",
    "@rsbuild/plugin-react": "1.1.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cspell": "^10.0.1",
    "knip": "^6.16.1",
    "lefthook": "^2.1.9",
    "nx": "23.0.1",
    "prettier": "^3.8.1",
    "tslib": "^2.3.0",
    "typescript": "~6.0.3"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}

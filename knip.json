{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    ".agents/**",
    ".github/skills/**",
    ".opencode/**",
    "apps/frontend/src/styles.d.ts",
    "apps/backend/webpack.config.js",
    "apps/backend/webpack-hmr.config.js"
  ],
  "ignoreDependencies": [
    "@commitlint/cli",
    "@commitlint/config-conventional",
    "@nestjs/schematics",
    "@nestjs/testing",
    "@nx/devkit",
    "@nx/nest",
    "@nx/node",
    "@nx/web",
    "@nx/webpack",
    "cspell",
    "knip",
    "lefthook",
    "prettier",
    "run-script-webpack-plugin",
    "ts-loader",
    "webpack",
    "webpack-cli",
    "webpack-dev-server",
    "webpack-node-externals"
  ],
  "workspaces": {
    "apps/frontend": {
      "ignoreDependencies": ["@rsdoctor/rspack-plugin", "cross-env"],
      "ignoreExportsUsedInFile": true,
      "ignoreIssues": {
        "src/app/**": ["exports", "duplicates"]
      }
    },
    "apps/frontend-e2e": {
      "entry": ["playwright.config.mts", "src/**/*.spec.ts"],
      "ignoreDependencies": ["@playwright/test"]
    },
    "apps/backend": {
      "entry": ["src/main.ts"],
      "webpack": false,
      "ignoreDependencies": ["@nestjs/testing", "tslib"]
    }
  }
}
